{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "char/**",    "use": "@vercel/static" },
    { "src": "bgm/**",     "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/char/(.*)", "dest": "/char/$1" },
    { "src": "/bgm/(.*)",  "dest": "/bgm/$1" },
    { "src": "/(.*)",      "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/char/(.*)",
      "headers": [
        { "key": "Cache-Control",              "value": "public, max-age=86400" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/bgm/(.*)",
      "headers": [
        { "key": "Cache-Control",  "value": "public, max-age=86400" },
        { "key": "Accept-Ranges",  "value": "bytes" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
